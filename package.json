{
  "name": "context-cue",
  "private": true,
  "version": "0.1.0",
  "description": "How to Talk / Context Cue monorepo",
  "packageManager": "pnpm@10.15.1",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "corepack pnpm --filter desktop dev",
    "build": "corepack pnpm --filter desktop build",
